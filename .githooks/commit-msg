#!/usr/bin/env bash
# Strips any "Co-Authored-By: Claude*" lines from commit messages.
set -euo pipefail

COMMIT_MSG_FILE="$1"

# Remove lines matching co-author attribution (case-insensitive)
sed -i '' '/^Co-Authored-By:.*[Cc]laude/Id' "$COMMIT_MSG_FILE"

# Clean up any trailing blank lines left behind
sed -i '' -e 's/[[:space:]]*$//' "$COMMIT_MSG_FILE"

exit 0
